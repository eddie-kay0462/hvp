# Supabase — get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Service role key bypasses RLS. Never expose this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Payment checkout: paystack (default) | momo_manual
# momo_manual = show Hustle Village MoMo number + buyer submits txn ID + screenshot; admin verifies in dashboard.
PAYMENT_PROVIDER=paystack

# Manual Mobile Money (when PAYMENT_PROVIDER=momo_manual)
MOMO_MERCHANT_NAME=Hustle Village
MOMO_DISPLAY_NUMBER=05XXXXXXXX
# Comma-separated labels for the checkout screen
MOMO_NETWORKS=MTN,Vodafone,AirtelTigo
# Shown to buyers as expected verification time (hours)
MOMO_PAYMENT_SLA_HOURS=24
# Optional extra instructions (multiline ok)
# MOMO_INSTRUCTIONS=Use "Send Money" and double-check the recipient name before confirming.

# Supabase Storage bucket for receipt screenshots (create in Dashboard → Storage)
MOMO_PROOF_BUCKET=payment-proofs

# Paystack — get from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=GHS

# Zoho Mail SMTP — use an App Password, not your main account password.
# Generate one at: Zoho Mail → Settings → Security → App Passwords
# Host options: smtp.zoho.com (global) | smtp.zoho.eu (EU) | smtp.zoho.in (India)
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=noreply@yourdomain.com
ZOHO_SMTP_PASS=your-zoho-app-password

# Optional — Resend (HTTPS; works when cloud hosts block SMTP). If set, tried before Zoho.
# RESEND_API_KEY=re_xxxxxxxx
# FROM_EMAIL=noreply@yourdomain.com

# Email addresses
ADMIN_EMAIL=admin@yourdomain.com

# Server
PORT=3000
NODE_ENV=production
# App URL (Paystack callbacks, etc.). Use your real production hostname.
FRONTEND_URL=https://hustlevillage.app

# Optional: overrides FRONTEND_URL for Supabase confirmation / verification emails only.
# Set if FRONTEND_URL still points at an old domain but users should verify on hustlevillage.app.
# Supabase Dashboard → Authentication → URL Configuration must allow this origin and
# Redirect URLs must include https://hustlevillage.app/verify-email (and www if you use it).
# AUTH_SITE_URL=https://hustlevillage.app
